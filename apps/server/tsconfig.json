{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@soulane/shared": ["../../packages/sync-core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/sync-core/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
